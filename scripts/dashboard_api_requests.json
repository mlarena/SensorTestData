{
  "dashboard": {
    "title": "ASP.NET Core Web API - Production Monitoring",
    "tags": ["dotnet", "aspnetcore", "webapi"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "🚀 API Requests Overview",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
      },
      {
        "title": "Requests per Second by Endpoint",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (endpoint) (rate(http_requests_received_total[$__rate_interval]))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
        "fieldConfig": {"defaults": {"unit": "reqps"}}
      },
      {
        "title": "Total Requests (Cumulative)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(http_requests_received_total)",
            "legendFormat": "Total Requests"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
        "options": {"colorMode": "value", "graphMode": "area"}
      },
      {
        "title": "Requests by Endpoint (Pie)",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (endpoint) (http_requests_received_total)",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1}
      },
      {
        "title": "Top Requested Endpoints",
        "type": "barchart",
        "targets": [
          {
            "expr": "topk(10, sum by (endpoint) (rate(http_requests_received_total[$__rate_interval])))",
            "legendFormat": "{{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9}
      },
      {
        "title": "HTTP Status Codes Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (code) (http_requests_received_total)",
            "legendFormat": "{{code}}"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 9}
      },
      {
        "title": "Error Rate (404s)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(http_requests_received_total{code=\"404\"})",
            "legendFormat": "404 Errors"
          }
        ],
        "gridPos": {"h": 4, "w": 3, "x": 18, "y": 9},
        "options": {"colorMode": "value", "graphMode": "area", "textMode": "value_and_name"}
      },
      {
        "title": "Success Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(http_requests_received_total{code=\"200\"}) / sum(http_requests_received_total) * 100",
            "legendFormat": "Success %"
          }
        ],
        "gridPos": {"h": 4, "w": 3, "x": 21, "y": 9},
        "options": {"colorMode": "value", "graphMode": "none"},
        "fieldConfig": {"defaults": {"unit": "percent"}}
      },
      {
        "title": "⏱️ Performance Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17}
      },
      {
        "title": "Request Duration - 95th Percentile",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[$__rate_interval])) by (le, endpoint))",
            "legendFormat": "p95 - {{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
        "fieldConfig": {"defaults": {"unit": "s"}}
      },
      {
        "title": "Request Duration - Heatmap",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_bucket[$__rate_interval])) by (le)",
            "format": "heatmap",
            "legendFormat": "{{le}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18}
      },
      {
        "title": "Active Requests in Progress",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(http_requests_in_progress)",
            "legendFormat": "Active Requests"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26}
      },
      {
        "title": "💻 .NET Runtime Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34}
      },
      {
        "title": "Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "dotnet_total_memory_bytes / 1024 / 1024",
            "legendFormat": ".NET Memory (MB)"
          },
          {
            "expr": "process_working_set_bytes / 1024 / 1024",
            "legendFormat": "Working Set (MB)"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 35},
        "fieldConfig": {"defaults": {"unit": "bytes"}}
      },
      {
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[$__rate_interval])",
            "legendFormat": "CPU Cores"
          },
          {
            "expr": "system_runtime_cpu_usage",
            "legendFormat": "CPU %"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 35},
        "fieldConfig": {"defaults": {"unit": "percent"}}
      },
      {
        "title": "GC Collections",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(dotnet_collection_count_total{generation=\"0\"}[$__rate_interval])",
            "legendFormat": "Gen 0 GC"
          },
          {
            "expr": "rate(dotnet_collection_count_total{generation=\"1\"}[$__rate_interval])",
            "legendFormat": "Gen 1 GC"
          },
          {
            "expr": "rate(dotnet_collection_count_total{generation=\"2\"}[$__rate_interval])",
            "legendFormat": "Gen 2 GC"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 35}
      },
      {
        "title": "GC Heap Size",
        "type": "timeseries",
        "targets": [
          {
            "expr": "system_runtime_gc_heap_size",
            "legendFormat": "Heap Size (MB)"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 43},
        "fieldConfig": {"defaults": {"unit": "bytes"}}
      },
      {
        "title": "Exceptions Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(system_runtime_exception_count_total[$__rate_interval])",
            "legendFormat": "Exceptions/s"
          },
          {
            "expr": "rate(system_runtime_dotnet_exceptions[$__rate_interval])",
            "legendFormat": ".NET Exceptions/s"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 43},
        "fieldConfig": {"defaults": {"unit": "cps"}}
      },
      {
        "title": "ThreadPool Stats",
        "type": "timeseries",
        "targets": [
          {
            "expr": "system_runtime_threadpool_thread_count",
            "legendFormat": "Threads"
          },
          {
            "expr": "system_runtime_threadpool_queue_length",
            "legendFormat": "Queue Length"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 43}
      },
      {
        "title": "🔌 Kestrel Server Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 51}
      },
      {
        "title": "Active Connections",
        "type": "timeseries",
        "targets": [
          {
            "expr": "microsoft_aspnetcore_server_kestrel_current_connections",
            "legendFormat": "Active Connections"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 52}
      },
      {
        "title": "Connection Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(microsoft_aspnetcore_server_kestrel_connections_per_second_total[$__rate_interval])",
            "legendFormat": "New Connections/s"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 52},
        "fieldConfig": {"defaults": {"unit": "cps"}}
      },
      {
        "title": "Queue Lengths",
        "type": "timeseries",
        "targets": [
          {
            "expr": "microsoft_aspnetcore_server_kestrel_connection_queue_length",
            "legendFormat": "Connection Queue"
          },
          {
            "expr": "microsoft_aspnetcore_server_kestrel_request_queue_length",
            "legendFormat": "Request Queue"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 52}
      },
      {
        "title": "🏷️ Routing Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 60}
      },
      {
        "title": "Route Matching Success",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (http_route) (rate(microsoft_aspnetcore_routing_aspnetcore_routing_match_attempts{aspnetcore_routing_match_status=\"success\"}[$__rate_interval]))",
            "legendFormat": "{{http_route}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 61}
      },
      {
        "title": "📊 System Metrics",
        "type": "row",
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 69}
      },
      {
        "title": "Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "time() - process_start_time_seconds",
            "legendFormat": "Uptime"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 70},
        "options": {"colorMode": "none", "graphMode": "none"},
        "fieldConfig": {"defaults": {"unit": "s"}}
      },
      {
        "title": "Open Handles",
        "type": "timeseries",
        "targets": [
          {
            "expr": "process_open_handles",
            "legendFormat": "Open Handles"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 4, "y": 70}
      },
      {
        "title": "Thread Count",
        "type": "timeseries",
        "targets": [
          {
            "expr": "process_num_threads",
            "legendFormat": "Threads"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 12, "y": 70}
      },
      {
        "title": "Assembly Load Count",
        "type": "stat",
        "targets": [
          {
            "expr": "system_runtime_assembly_count",
            "legendFormat": "Loaded Assemblies"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 70},
        "options": {"colorMode": "value", "graphMode": "none"}
      }
    ],
    "time": {"from": "now-1h", "to": "now"}
  }
}